<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jogo do Lobo - Jogando</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #1a1a2e, #16213e);
            min-height: 100vh;
            color: white;
        }

        .header {
            background: rgba(0, 0, 0, 0.5);
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .jogador-info {
            font-size: 18px;
        }

        .sair {
            background: #e74c3c;
            padding: 8px 20px;
            border-radius: 10px;
            text-decoration: none;
            color: white;
            transition: 0.3s;
        }

        .sair:hover {
            background: #c0392b;
        }

        .game-area {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 80vh;
            flex-direction: column;
        }

        .mensagem-boas-vindas {
            background: rgba(255, 255, 255, 0.1);
            padding: 30px;
            border-radius: 20px;
            text-align: center;
        }

        h1 {
            font-size: 2.5em;
            margin-bottom: 20px;
            color: #e74c3c;
        }

        p {
            font-size: 1.2em;
            margin: 10px 0;
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="jogador-info">
             Jogador: <strong><%= nome %></strong>
        </div>
        <a href="/" class="sair">🚪 Sair</a>
        <button id="criar" class="sair">TESTE</button>
    </div>

    <div class="game-area">
        <div class="mensagem-boas-vindas">
            <h1> Bem-vindo ao Jogo Lobitos, <%= nome %>!</h1>
            <p> O lobo está à solta...</p>
        
        </div>
    </div>
    <script src="../socket.io/socket.io.js"></script>
    <script src="js/main.js"></script>
</body>
</html>